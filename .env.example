# =============================================================================
# FamilyMind 2.0 - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual credentials:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Postgres connection strings (both needed for Prisma)
DATABASE_URL=your_database_url
DIRECT_URL=your_direct_url

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# -----------------------------------------------------------------------------
# Bunny.net Stream (video hosting)
# -----------------------------------------------------------------------------
BUNNY_API_KEY=your_bunny_api_key
BUNNY_LIBRARY_ID=your_bunny_library_id
BUNNY_CDN_HOSTNAME=your_bunny_cdn_hostname
BUNNY_TOKEN_AUTH_KEY=your_bunny_token_auth_key

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=FamilyMind <noreply@familymind.dk>

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token
