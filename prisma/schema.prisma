// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum MediaType {
  VIDEO
  AUDIO
  PDF
  TEXT
}

enum Difficulty {
  INTRODUCTORY
  INTERMEDIATE
  ADVANCED
}

enum EntitlementSource {
  PURCHASE
  SUBSCRIPTION
  GIFT
  B2B_LICENSE
}

enum EntitlementStatus {
  ACTIVE
  PAUSED
  PAST_DUE
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountDuration {
  once
  repeating
  forever
}

enum QuestionType {
  SINGLE_SELECT
  MULTI_SELECT
  DATE
  SLIDER
}

enum NotificationType {
  WEEKLY_PLAN
  MIDWEEK_NUDGE
  REFLECTION
  MONTHLY_PROGRESS
}

enum MilestoneTriggerType {
  DAYS_ACTIVE
  PHASE_COMPLETE
  JOURNEY_COMPLETE
  CONTENT_COUNT
  CHECKIN_STREAK
}

enum InAppNotificationType {
  WEEKLY_PLAN
  MIDWEEK_NUDGE
  REFLECTION
  MILESTONE
  REENGAGEMENT
  COMMUNITY_REPLY
  SYSTEM
}

enum JourneyStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum BillingType {
  one_time
  recurring
}

enum BillingInterval {
  month
  year
}

enum RetentionOfferType {
  DISCOUNT
  PAUSE
  SUPPORT
  CONTENT_HELP
  NONE
}

// ──────────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  name                String?
  role                UserRole  @default(USER)
  organizationId      String?   @db.Uuid
  onboardingCompleted Boolean   @default(false)
  hasSeenWelcome      Boolean   @default(false)
  lastActiveAt        DateTime?
  // Stripe Customer for the platform (or default org). Multi-tenant Connect
  // setups will need a (userId, orgId) -> customerId join table; until then
  // this column is sufficient.
  stripeCustomerId    String?   @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization?         @relation(fields: [organizationId], references: [id])
  entitlements        Entitlement[]
  contentProgress     UserContentProgress[]
  userJourneys        UserJourney[]
  userProfile         UserProfile?
  notifications       Notification[]
  notificationLog     UserNotificationLog[]
  cohortMemberships   CohortMember[]
  discussionPosts     DiscussionPost[]
  discussionReplies   DiscussionReply[]
  postReactions       PostReaction[]
  cohortBans          CohortBan[]
  contentReports      ContentReport[]
  cookieConsents      CookieConsent[]
  tags                UserTag[]
  savedContent        SavedContent[]
  cancellationSurveys CancellationSurvey[]

  @@index([lastActiveAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, lastActiveAt])
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Stripe Connect ──
  stripeAccountId     String?   @unique
  stripeAccountStatus String    @default("not_connected")
  stripeOnboardedAt   DateTime?

  // ── Brand ──
  brandName   String  @default("FamilyMind")
  tagline     String?
  description String?
  logoUrl     String?
  faviconUrl  String?
  websiteUrl  String?

  // ── Farver (hex) ──
  colorPrimary           String @default("#86A0A6")
  colorPrimaryForeground String @default("#1A1A1A")
  colorAccent            String @default("#E8715A")
  colorSuccess           String @default("#2A6B5A")
  colorBackground        String @default("#FAFAF8")
  colorSand              String @default("#F5F0EB")
  colorForeground        String @default("#1A1A1A")
  colorBorder            String @default("#E8E4DF")

  // ── Kontakt ──
  contactEmail String?
  contactPhone String?
  contactUrl   String?

  // ── Email ──
  emailFromName  String?
  emailFromEmail String?

  // ── Landing page hero ──
  heroHeading    String?
  heroSubheading String?
  heroCtaText    String?
  heroCtaUrl     String?

  // ── Om-sektion ──
  aboutHeading  String?
  aboutName     String?
  aboutBio      String?
  aboutUrl      String?
  aboutImageUrl String?

  // ── Landing page JSON-sektioner ──
  landingBenefits     Json?
  landingSteps        Json?
  landingFeatures     Json?
  landingTestimonials Json?
  landingFaq          Json?

  // ── Priser (display) ──
  subscriptionPriceDisplay  String?
  subscriptionPeriodDisplay String?

  // ── Footer ──
  footerCopyright String?
  footerLinks     Json?

  // ── Relations ──
  users        User[]
  entitlements Entitlement[]
}

model ContentUnit {
  id              String     @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  slug            String     @unique
  mediaType       MediaType
  mediaUrl        String?
  bunnyVideoId    String?
  thumbnailUrl    String?
  durationMinutes Int?
  difficulty      Difficulty @default(INTRODUCTORY)
  ageMin          Float? // years (decimals allowed, e.g. 0.5 = 6 months)
  ageMax          Float? // years (decimals allowed, e.g. 0.5 = 6 months)
  isFree          Boolean    @default(false)
  bodyHtml        String? // Rich text artikelindhold (HTML) — bruges når mediaType=TEXT
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tags               ContentUnitTag[]
  courseLessons      CourseLesson[]
  journeyDayContents JourneyDayContent[]
  userProgress       UserContentProgress[]
  savedContent       SavedContent[]
}

model ContentTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())

  contentUnits      ContentUnitTag[]
  onboardingOptions OnboardingOption[]
  communityRooms    CommunityRoomTag[]
  users             UserTag[]
  dashboardMessages DashboardMessage[]
}

model ContentUnitTag {
  contentUnitId String @db.Uuid
  tagId         String @db.Uuid

  contentUnit ContentUnit @relation(fields: [contentUnitId], references: [id], onDelete: Cascade)
  tag         ContentTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentUnitId, tagId])
}

model Course {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  slug            String   @unique
  coverImageUrl   String?
  landingPage     Json?
  isActive        Boolean  @default(true)
  showStandalone  Boolean  @default(false)
  stripeProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modules       CourseModule[]
  lessons       CourseLesson[]
  priceVariants PriceVariant[]
  entitlements  Entitlement[]
  bundles       BundleCourse[]
  journeys      Journey[]
  discountCodes DiscountCode[]

  @@index([isActive])
}

model Bundle {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  slug            String   @unique
  coverImageUrl   String?
  landingPage     Json?
  isActive        Boolean  @default(true)
  stripeProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courses       BundleCourse[]
  priceVariants PriceVariant[]
  entitlements  Entitlement[]
  discountCodes DiscountCode[]

  @@index([isActive])
}

model BundleCourse {
  id       String @id @default(uuid()) @db.Uuid
  bundleId String @db.Uuid
  courseId String @db.Uuid
  position Int    @default(0)

  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseId])
  @@index([bundleId, position])
}

model PriceVariant {
  id            String           @id @default(uuid()) @db.Uuid
  courseId      String?          @db.Uuid
  bundleId      String?          @db.Uuid
  label         String
  description   String?
  amountCents   Int
  currency      String           @default("DKK")
  billingType   BillingType
  interval      BillingInterval?
  intervalCount Int              @default(1)
  trialDays     Int?
  stripePriceId String?
  position      Int              @default(0)
  isActive      Boolean          @default(true)
  isHighlighted Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  bundle       Bundle?       @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  entitlements Entitlement[]

  @@index([courseId, position])
  @@index([bundleId, position])
}

model CourseLesson {
  id            String  @id @default(uuid()) @db.Uuid
  courseId      String  @db.Uuid
  contentUnitId String  @db.Uuid
  moduleId      String? @db.Uuid
  position      Int
  isFreePreview Boolean @default(false)

  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contentUnit ContentUnit   @relation(fields: [contentUnitId], references: [id], onDelete: Cascade)
  module      CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@unique([courseId, contentUnitId])
  @@index([courseId, position])
}

model CourseModule {
  id          String  @id @default(uuid()) @db.Uuid
  courseId    String  @db.Uuid
  title       String
  description String?
  position    Int

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([courseId])
}

model Entitlement {
  id                      String            @id @default(uuid()) @db.Uuid
  userId                  String            @db.Uuid
  organizationId          String?           @db.Uuid
  courseId                String?           @db.Uuid
  bundleId                String?           @db.Uuid
  priceVariantId          String?           @db.Uuid
  source                  EntitlementSource
  status                  EntitlementStatus @default(ACTIVE)
  stripeSubscriptionId    String?
  stripeCheckoutSessionId String?           @unique
  paidAmountCents         Int?
  paidCurrency            String?
  expiresAt               DateTime?
  cancelledAt             DateTime?
  // Set when status=PAUSED. Cleared when subscription resumes. Mirrors
  // Stripe's pause_collection.resumes_at so UI can show "paused until X".
  pausedUntil             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @default(now()) @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization?       @relation(fields: [organizationId], references: [id])
  course             Course?             @relation(fields: [courseId], references: [id])
  bundle             Bundle?             @relation(fields: [bundleId], references: [id])
  priceVariant       PriceVariant?       @relation(fields: [priceVariantId], references: [id])
  cancellationSurvey CancellationSurvey?

  @@index([userId, status])
  @@index([userId, status, courseId])
  @@index([userId, status, bundleId])
  @@index([stripeSubscriptionId])
  @@index([organizationId, status])
  @@index([status, cancelledAt])
}

model DiscountCode {
  id                 String           @id @default(uuid()) @db.Uuid
  code               String           @unique
  type               DiscountType
  value              Int
  maxUses            Int?
  currentUses        Int              @default(0)
  validFrom          DateTime         @default(now())
  validUntil         DateTime?
  applicableCourseId String?          @db.Uuid
  applicableBundleId String?          @db.Uuid
  isActive           Boolean          @default(true)
  stripeCouponId     String?
  duration           DiscountDuration @default(once)
  durationInMonths   Int?

  applicableCourse Course? @relation(fields: [applicableCourseId], references: [id])
  applicableBundle Bundle? @relation(fields: [applicableBundleId], references: [id])
}

model UserContentProgress {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  contentUnitId String    @db.Uuid
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentUnit ContentUnit @relation(fields: [contentUnitId], references: [id], onDelete: Cascade)

  @@unique([userId, contentUnitId])
  @@index([userId, completedAt])
}

model SavedContent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  contentUnitId String   @db.Uuid
  savedAt       DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentUnit ContentUnit @relation(fields: [contentUnitId], references: [id], onDelete: Cascade)

  @@unique([userId, contentUnitId])
  @@index([userId, savedAt])
}

// ──────────────────────────────────────────────
// Journey Models
// ──────────────────────────────────────────────

model Journey {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  slug          String   @unique
  targetAgeMin  Float? // years (decimals allowed)
  targetAgeMax  Float? // years (decimals allowed)
  estimatedDays Int?
  isActive      Boolean  @default(true)
  courseId      String?  @db.Uuid
  coverImageUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course       Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  phases       JourneyPhase[]
  userJourneys UserJourney[]
  cohorts      Cohort[]
}

model JourneyPhase {
  id        String @id @default(uuid()) @db.Uuid
  journeyId String @db.Uuid
  title     String
  position  Int

  journey Journey      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  days    JourneyDay[]

  @@index([journeyId, position])
}

model JourneyDay {
  id       String  @id @default(uuid()) @db.Uuid
  phaseId  String  @db.Uuid
  position Int
  title    String?

  phase              JourneyPhase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  contents           JourneyDayContent[]
  actions            JourneyDayAction[]
  userCheckIns       UserDayCheckIn[]
  currentForJourneys UserJourney[]
  discussionPrompts  DiscussionPrompt[]
  discussionPosts    DiscussionPost[]

  @@index([phaseId, position])
}

model JourneyDayContent {
  id            String @id @default(uuid()) @db.Uuid
  dayId         String @db.Uuid
  contentUnitId String @db.Uuid
  position      Int

  day         JourneyDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)
  contentUnit ContentUnit @relation(fields: [contentUnitId], references: [id], onDelete: Cascade)

  @@index([dayId, position])
}

model JourneyDayAction {
  id               String  @id @default(uuid()) @db.Uuid
  dayId            String  @db.Uuid
  actionText       String // "Pr0v dette med dit barn i dag"
  reflectionPrompt String? // "Hvordan gik det?"

  day JourneyDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model UserJourney {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  journeyId    String        @db.Uuid
  currentDayId String?       @db.Uuid
  startedAt    DateTime      @default(now())
  completedAt  DateTime?
  status       JourneyStatus @default(ACTIVE)

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  journey    Journey          @relation(fields: [journeyId], references: [id])
  currentDay JourneyDay?      @relation(fields: [currentDayId], references: [id])
  checkIns   UserDayCheckIn[]

  @@index([userId, status])
  @@index([userId, completedAt])
}

model UserDayCheckIn {
  id              String   @id @default(uuid()) @db.Uuid
  userJourneyId   String   @db.Uuid
  dayId           String   @db.Uuid
  checkInOptionId String   @db.Uuid
  reflection      String?
  completedAt     DateTime @default(now())

  userJourney   UserJourney   @relation(fields: [userJourneyId], references: [id], onDelete: Cascade)
  day           JourneyDay    @relation(fields: [dayId], references: [id])
  checkInOption CheckInOption @relation(fields: [checkInOptionId], references: [id])

  @@index([userJourneyId])
}

model UserProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @db.Uuid
  responses             Json? // array of {questionId, selectedOptionIds}
  childAges             Json? // array of ages in years (decimals allowed) derived from SLIDER/DATE responses
  primaryChallengeTagId String?   @db.Uuid
  completedAt           DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Admin-Configurable Models
// ──────────────────────────────────────────────

model SiteSetting {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  value       String
  description String?
}

model OnboardingQuestion {
  id           String       @id @default(uuid()) @db.Uuid
  questionText String
  questionType QuestionType
  position     Int
  isActive     Boolean      @default(true)
  helperText   String?

  options OnboardingOption[]
}

model OnboardingOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @db.Uuid
  label      String
  value      String
  tagId      String? @db.Uuid
  position   Int

  question OnboardingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      ContentTag?        @relation(fields: [tagId], references: [id])
}

model RecommendationRule {
  id         String  @id @default(uuid()) @db.Uuid
  name       String
  conditions Json // e.g. {"tagId": "x", "ageMin": 0, "ageMax": 3} (ageMin/ageMax in years, decimals allowed)
  targetType String // "JOURNEY" or "PRODUCT"
  targetId   String  @db.Uuid
  priority   Int     @default(0)
  isActive   Boolean @default(true)
}

model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  templateKey String   @unique
  subject     String
  bodyHtml    String
  description String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  reEngagementTiers ReEngagementTier[]
}

model NotificationSchedule {
  id               String           @id @default(uuid()) @db.Uuid
  notificationType NotificationType
  dayOfWeek        Int // 0-6
  timeOfDay        String // HH:MM
  isActive         Boolean          @default(true)
}

model ReEngagementTier {
  id              String  @id @default(uuid()) @db.Uuid
  tierNumber      Int     @unique
  daysInactiveMin Int
  daysInactiveMax Int
  emailTemplateId String  @db.Uuid
  isActive        Boolean @default(true)

  emailTemplate EmailTemplate @relation(fields: [emailTemplateId], references: [id])
}

model MilestoneDefinition {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String
  triggerType        MilestoneTriggerType
  triggerValue       Int
  celebrationTitle   String
  celebrationMessage String
  isActive           Boolean              @default(true)
}

model CheckInOption {
  id       String  @id @default(uuid()) @db.Uuid
  label    String
  value    String
  emoji    String?
  position Int
  isActive Boolean @default(true)

  checkIns UserDayCheckIn[]
}

model DashboardMessage {
  id       String  @id @default(uuid()) @db.Uuid
  stateKey String
  tagId    String? @db.Uuid
  heading  String
  body     String
  ctaLabel String?
  ctaUrl   String?

  tag ContentTag? @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([stateKey, tagId])
  @@index([stateKey])
}

model Notification {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @db.Uuid
  type      InAppNotificationType
  title     String
  body      String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model UserNotificationLog {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  type   String // "engagement" or "reengagement"
  key    String // notification type (e.g. "WEEKLY_PLAN") or tier number (e.g. "1")
  sentAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, key])
  @@index([userId, type, sentAt])
}

model CookieConsent {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  ipHash      String
  statistics  Boolean  @default(false)
  marketing   Boolean  @default(false)
  consentedAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ──────────────────────────────────────────────
// Community / Cohort Models
// ──────────────────────────────────────────────

model Cohort {
  id         String   @id @default(uuid()) @db.Uuid
  journeyId  String   @db.Uuid
  name       String?
  maxMembers Int      @default(25)
  isOpen     Boolean  @default(true)
  startDate  DateTime @default(now())
  createdAt  DateTime @default(now())

  journey Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  members CohortMember[]
  posts   DiscussionPost[]
  bans    CohortBan[]

  @@index([journeyId, isOpen])
}

model CohortMember {
  id       String   @id @default(uuid()) @db.Uuid
  cohortId String   @db.Uuid
  userId   String   @db.Uuid
  joinedAt DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([userId])
}

model DiscussionPrompt {
  id         String  @id @default(uuid()) @db.Uuid
  dayId      String  @db.Uuid
  promptText String
  isActive   Boolean @default(true)

  day   JourneyDay       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  posts DiscussionPost[]

  @@index([dayId])
}

model DiscussionPost {
  id             String   @id @default(uuid()) @db.Uuid
  cohortId       String?  @db.Uuid
  roomId         String?  @db.Uuid
  organizationId String?  @db.Uuid
  authorId       String   @db.Uuid
  dayId          String?  @db.Uuid
  promptId       String?  @db.Uuid
  slug           String?  @unique
  body           String
  isPrompt       Boolean  @default(false)
  isPinned       Boolean  @default(false)
  isHidden       Boolean  @default(false)
  isPublic       Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cohort    Cohort?           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  room      CommunityRoom?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  day       JourneyDay?       @relation(fields: [dayId], references: [id])
  prompt    DiscussionPrompt? @relation(fields: [promptId], references: [id])
  replies   DiscussionReply[]
  reactions PostReaction[]
  reports   ContentReport[]   @relation("PostReports")

  @@index([cohortId, createdAt])
  @@index([roomId, createdAt])
  @@index([slug])
  @@index([authorId])
}

model DiscussionReply {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  authorId  String   @db.Uuid
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      DiscussionPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions PostReaction[]
  reports   ContentReport[] @relation("ReplyReports")

  @@index([postId, createdAt])
  @@index([authorId])
}

model PostReaction {
  id      String  @id @default(uuid()) @db.Uuid
  userId  String  @db.Uuid
  postId  String? @db.Uuid
  replyId String? @db.Uuid
  emoji   String  @default("❤️")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  DiscussionPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply DiscussionReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@unique([userId, replyId, emoji])
  @@index([postId])
  @@index([replyId])
}

model CohortBan {
  id       String   @id @default(uuid()) @db.Uuid
  cohortId String   @db.Uuid
  userId   String   @db.Uuid
  reason   String?
  bannedAt DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([userId])
}

model CommunityRoom {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  name           String
  slug           String   @unique
  description    String?
  icon           String? // lucide icon name, e.g. "MessageCircle"
  sortOrder      Int      @default(0)
  isPublic       Boolean  @default(true)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts       DiscussionPost[]
  promptQueue RoomPromptQueue[]
  tags        CommunityRoomTag[]

  @@index([isArchived, sortOrder])
}

model CommunityRoomTag {
  roomId String @db.Uuid
  tagId  String @db.Uuid

  room CommunityRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tag  ContentTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([roomId, tagId])
}

model RoomPromptQueue {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @db.Uuid
  roomId         String    @db.Uuid
  promptText     String
  priority       Int       @default(0)
  postedAt       DateTime?
  isPaused       Boolean   @default(false)
  createdAt      DateTime  @default(now())

  room CommunityRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, postedAt, isPaused])
}

model ContentReport {
  id         String       @id @default(uuid()) @db.Uuid
  reporterId String       @db.Uuid
  postId     String?      @db.Uuid
  replyId    String?      @db.Uuid
  reason     String
  status     ReportStatus @default(PENDING)
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())

  reporter User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  post     DiscussionPost?  @relation("PostReports", fields: [postId], references: [id], onDelete: Cascade)
  reply    DiscussionReply? @relation("ReplyReports", fields: [replyId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([postId])
  @@index([replyId])
}

// ──────────────────────────────────────────────
// User Tagging (unified with ContentTag)
// ──────────────────────────────────────────────

model UserTag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  ContentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

// ──────────────────────────────────────────────
// Offboarding / Cancellation Models
// ──────────────────────────────────────────────

model CancellationReason {
  id    String @id @default(uuid()) @db.Uuid
  slug  String @unique
  label String

  primarySurveys CancellationSurvey[]    @relation("PrimaryReason")
  surveyTags     CancellationSurveyTag[]
  offerTriggers  RetentionOfferTrigger[]
}

model CancellationSurvey {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  entitlementId   String    @unique @db.Uuid
  submittedAt     DateTime  @default(now())
  cancelledAt     DateTime?
  primaryReasonId String?   @db.Uuid
  feedback        String?
  wouldReturn     Boolean?
  offeredPause    Boolean   @default(false)
  pauseAccepted   Boolean   @default(false)

  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entitlement         Entitlement               @relation(fields: [entitlementId], references: [id])
  primaryReason       CancellationReason?       @relation("PrimaryReason", fields: [primaryReasonId], references: [id])
  tags                CancellationSurveyTag[]
  retentionAcceptance RetentionOfferAcceptance?

  @@unique([userId, entitlementId])
  @@index([userId, submittedAt])
  @@index([cancelledAt])
}

model CancellationSurveyTag {
  surveyId String @db.Uuid
  reasonId String @db.Uuid

  survey CancellationSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  reason CancellationReason @relation(fields: [reasonId], references: [id])

  @@id([surveyId, reasonId])
}

// ──────────────────────────────────────────────
// Retention Offer Engine Models
// ──────────────────────────────────────────────

model RetentionOffer {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String?            @db.Uuid
  name           String
  offerType      RetentionOfferType
  isActive       Boolean            @default(true)
  priority       Int                @default(0)

  maxUsesPerUser Int @default(1)
  cooldownDays   Int @default(365)

  stripeCouponId String?
  durationMonths Int?

  pauseMonths Int?

  supportUrl     String?
  supportMessage String?

  contentUrl     String?
  contentMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  triggers    RetentionOfferTrigger[]
  acceptances RetentionOfferAcceptance[]

  @@index([organizationId, isActive, priority])
  @@index([offerType, isActive])
}

model RetentionOfferTrigger {
  id                   String @id @default(uuid()) @db.Uuid
  offerId              String @db.Uuid
  cancellationReasonId String @db.Uuid

  offer              RetentionOffer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  cancellationReason CancellationReason @relation(fields: [cancellationReasonId], references: [id])

  @@unique([offerId, cancellationReasonId])
  @@index([cancellationReasonId])
}

model RetentionOfferAcceptance {
  id         String             @id @default(uuid()) @db.Uuid
  offerId    String             @db.Uuid
  surveyId   String             @unique @db.Uuid
  userId     String             @db.Uuid
  acceptedAt DateTime           @default(now())
  offerType  RetentionOfferType
  expiresAt  DateTime?

  offer  RetentionOffer     @relation(fields: [offerId], references: [id])
  survey CancellationSurvey @relation(fields: [surveyId], references: [id])

  @@index([userId, acceptedAt])
  @@index([offerId, acceptedAt])
}
